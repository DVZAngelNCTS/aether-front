"use client";

import { useEffect } from "react";
import Link from "next/link";
import type { CreneauAvecOeuvre } from "@/data/planning";

interface Props {
  heure:   string;
  items:   CreneauAvecOeuvre[];
  onClose: () => void;
  now:     Date;
}

export default function ModalCreneau({ heure, items, onClose }: Props) {
