      let next: number;
      do { next = Math.floor(Math.random() * POOL.length); }
      while (next === index && POOL.length > 1);
      setIndex(next);
      setAnimating(false);
    }, 250);
  }, [animating, index]);

  return (
  <>
    {/* En-tête avec bouton — tout dans le même composant client */}
    <div className="flex items-center justify-between mb-6">
