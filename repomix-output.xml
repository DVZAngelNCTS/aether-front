@import "tailwindcss";

/* next-themes injecte data-theme="dark" sur <html> */
@variant dark (&:where([data-theme="dark"], [data-theme="dark"] *));

/* ── Thème clair (défaut) ── */
:root {
  --bg-base:        #d1d5db;   /* fond général — gris moyen */
  --bg-card:        #e5e7eb;   /* cartes — plus clair */
  --bg-nav:         #c4c9d4;   /* navbar / footer — plus sombre */
  --bg-input:       #dde0e7;   /* inputs */
  --border:         #b0b7c3;   /* bordures */
  --text-primary:   #111827;
  --text-muted:     #4b5563;
  --text-faint:     #6b7280;
  --bg-progress:    #b0b7c3;
  --bg-card-hover:  #d8dce5;
}

/* ── Thème sombre ── */
[data-theme="dark"] {
  --bg-base:        #030712;
  --bg-card:        #111827;
  --bg-nav:         #000000;
  --bg-input:       #111827;
  --border:         #1f2937;
  --text-primary:   #f9fafb;
  --text-muted:     #9ca3af;
  --text-faint:     #4b5563;
  --bg-progress:    #374151;
  --bg-card-hover:  #1f2937;
}

/* ── Tokens Tailwind v4 ── */
@theme inline {
  --color-bg-base:      var(--bg-base);
  --color-bg-card:      var(--bg-card);
  --color-bg-nav:       var(--bg-nav);
  --color-bg-input:     var(--bg-input);
  --color-border-base:  var(--border);
  --color-text-primary: var(--text-primary);
  --color-text-muted:   var(--text-muted);
  --color-text-faint:   var(--text-faint);
  --color-bg-progress:   var(--bg-progress);
  --color-bg-card-hover: var(--bg-card-hover);
}

body {
  background-color: var(--bg-base);
  color: var(--text-primary);
  transition: background-color 0.2s ease, color 0.2s ease;
}
